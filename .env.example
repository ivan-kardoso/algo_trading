################################################################################
# Bot Crypto - Configurações de Ambiente
################################################################################
# Este arquivo contém todas as variáveis de ambiente necessárias para executar
# o bot de trading Binance USDM Futures. Credenciais, timeouts, limites de retry
# e parâmetros de monitoramento são definidos aqui.
#
# ATENÇÃO: Este arquivo contém credenciais sensíveis. Nunca commite valores reais.
# Use .env.example como template e substitua com seus valores privados.
################################################################################


###############################################################################
# SEÇÃO 1: CREDENCIAIS BINANCE - AMBIENTE DE TESTE (TESTNET/SANDBOX)
###############################################################################
# Chave e segredo de API para operações em testnet. Use apenas para teste.
# Obtenha em: https://testnet.binance.vision/

BINANCE_API_KEY_TEST=
BINANCE_API_SECRET_TEST=


###############################################################################
# SEÇÃO 2: CREDENCIAIS BINANCE - AMBIENTE DE PRODUÇÃO
###############################################################################
# Chave e segredo de API para operações em produção (dinheiro real).
# Obtenha em: https://www.binance.com/en/account/api-management
# CUIDADO: Proteja essas credenciais. Nunca compartilhe ou commite.

BINANCE_API_KEY_PROD=
BINANCE_API_SECRET_PROD=